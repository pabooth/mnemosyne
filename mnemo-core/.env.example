# Main LLM — provider is one of: anthropic | openai | deepseek | xai | gemini | ollama
MAIN_LLM_PROVIDER=anthropic
MAIN_LLM_MODEL=claude-sonnet-4-6

# Anthropic (reference implementation)
ANTHROPIC_API_KEY=

# OpenAI-compatible (also used for Azure OpenAI — set OPENAI_BASE_URL accordingly)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=

# xAI / Grok (OpenAI-compatible API)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# Google Gemini (OpenAI-compatible API)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Ollama (no API key required — uses OpenAI-compatible endpoint)
OLLAMA_BASE_URL=http://localhost:11434

# ADR-011 requires different provider families for the two reviewer slots.
REVIEWER_ADVOCATE_PROVIDER=anthropic
REVIEWER_ADVOCATE_MODEL=claude-sonnet-4-6
REVIEWER_CRITIC_PROVIDER=openai
REVIEWER_CRITIC_MODEL=gpt-4o
ADVERSARIAL_REVIEW_ENABLED=false

# GitHub — required for the internal publish step used by ingest
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
DOCS_ROOT=

# Frontend origin — used to configure CORS
FRONTEND_ORIGIN=http://localhost:8888

# Intake API auth — required for REST process/ingest and MCP endpoints
MNEMO_API_TOKEN=
# Optional named tokens: alice:token-one:submitter,bob:token-two:admin
MNEMO_API_TOKENS=
REQUEST_TIMEOUT_SECONDS=120
REQUEST_RATE_LIMIT_PER_MINUTE=30
REQUEST_MAX_CONCURRENCY=4
REQUEST_MAX_BODY_BYTES=2000000
STATE_DB_PATH=./data/mnemosyne.db
JOB_MAX_ATTEMPTS=2
JOB_RETRY_BASE_SECONDS=1

GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_BRANCH=main
GITHUB_WEBHOOK_PATH_PREFIX=
GITHUB_WEBHOOK_MAX_FILES=20
SOURCE_URL_ALLOWED_HOSTS=

# Observability — leave empty to disable OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=mnemo-core
LOG_LEVEL=INFO
