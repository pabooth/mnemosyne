# LLM Provider — one of: anthropic | openai | deepseek | ollama
LLM_PROVIDER=anthropic

# Anthropic (reference implementation)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI-compatible (also used for Azure OpenAI — set OPENAI_BASE_URL accordingly)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Ollama (no API key required — uses OpenAI-compatible endpoint)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# GitHub — required for the internal publish step used by ingest
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Frontend origin — used to configure CORS
FRONTEND_ORIGIN=http://localhost:8888

# Intake API auth — required for REST process/ingest and MCP endpoints
MNEMO_API_TOKEN=

# Observability — leave empty to disable OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=mnemo-core
