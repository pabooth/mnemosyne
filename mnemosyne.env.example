# Start-time configuration for a Mnemosyne instance (ADR-017). Copy this
# file to $MNEMO_HOME/mnemosyne.env and point Docker Compose at it:
#
#   export MNEMO_HOME="$HOME/mnemosyne"        # /srv/mnemosyne on a server
#   export COMPOSE_ENV_FILES="$MNEMO_HOME/mnemosyne.env"
#
# MNEMO_HOME itself is a shell/deployment variable — do not set it in this
# file. Data lives in $MNEMO_HOME/data, one subdirectory per component.

# LLM API Settings, only used if the models are configured for the main provider, adversarial review, etc.
#
# Claude / Anthropic
ANTHROPIC_API_KEY=

# GPT / OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Grok / xAI
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# Gemini / Google
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# DeepSeek
DEEPSEEK_API_KEY=

# LLM Selection - embedding provider for the indexer is independent
# as at least Anthropic and DeepSeek currently don't offer an embeddings API.
MAIN_LLM_PROVIDER=anthropic
MAIN_LLM_MODEL=claude-sonnet-4-6
REVIEWER_CRITIC_PROVIDER=openai
REVIEWER_CRITIC_MODEL=gpt-4o
REVIEWER_JUDGE_PROVIDER=gemini
REVIEWER_JUDGE_MODEL=gemini-2.5-pro
ADVERSARIAL_REVIEW_ENABLED=false
EMBEDDING_PROVIDER=openai
EMBEDDING_OPENAI_MODEL=text-embedding-3-small
EMBEDDING_OLLAMA_MODEL=nomic-embed-text
INDEX_MAX_FILES=2000

# GitHub Settings
GITHUB_TOKEN=
GITHUB_REPO=owner/repository
DOCS_ROOT=
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_BRANCH=main
GITHUB_WEBHOOK_PATH_PREFIX=
GITHUB_WEBHOOK_MAX_FILES=20
SOURCE_URL_ALLOWED_HOSTS=

# Access to Mnemosyne itself
MNEMO_API_TOKEN=replace-with-a-long-random-value
MNEMO_API_TOKENS=

# ID Mnemosyne runs as, root is the compatibility default but this should be changed to non-root
MNEMO_UID=0
MNEMO_GID=0

# Network Settings
MNEMO_UI_BIND_ADDRESS=0.0.0.0
MNEMO_CORE_BIND_ADDRESS=127.0.0.1
MNEMO_OBSERVABILITY_BIND_ADDRESS=127.0.0.1
MNEMO_PORT_UI=8888
MNEMO_PORT_CORE=7777
FRONTEND_ORIGIN=http://localhost:8888
REQUEST_TIMEOUT_SECONDS=120
REQUEST_RATE_LIMIT_PER_MINUTE=30
REQUEST_MAX_CONCURRENCY=4
REQUEST_MAX_BODY_BYTES=2000000

# Job Settings
JOB_MAX_ATTEMPTS=2
JOB_RETRY_BASE_SECONDS=1

# Vector index (ADR-014/ADR-015). Embedded sqlite-vec by default, in its
# own file so embedding writes don't lock-contend with job status writes.
# VECTOR_DB_PATH is deliberately not set here: Docker Compose hardcodes it
# to /data/vectors.db (like STATE_DB_PATH), so a value in this file would
# override that with a path relative to the container's working directory
# instead of the bind-mounted data directory. Only set VECTOR_DB_PATH for
# a bare-metal (non-Docker) run; the application default is
# ./data/mnemo-core/vectors.db.
# VECTOR_EMBEDDING_DIM must match the active embedding model's output size
# (1536 for text-embedding-3-small, 768 for nomic-embed-text).
VECTOR_STORE=sqlite-vec
VECTOR_EMBEDDING_DIM=1536

# Read-path dedup check. Off by default: enabling it calls the embedding
# provider on every process/ingest call. Matches never block the pipeline —
# they're attached to the result and noted in the PR body for human review.
DEDUP_ENABLED=false
DEDUP_MAX_DISTANCE=0.35
DEDUP_TOP_K=3

# mnemo-curator is optional. Run with: docker compose --profile curator run --rm curator
CURATOR_STALE_AFTER_DAYS=180
CURATOR_MAX_FILES=500
CURATOR_DEFAULT_OWNER=unset
CURATOR_ISSUE_TRACKER=github
CURATOR_ISSUE_LABELS=mnemo-curator
# CURATOR_ISSUE_DB_PATH is deliberately not set here: like STATE_DB_PATH and
# VECTOR_DB_PATH, Docker Compose hardcodes it to a path on the bind-mounted
# data directory. Only set it for a bare-metal (non-Docker) run that needs a
# non-default location; the application default is
# ./data/mnemo-curator/issues.db.
CURATOR_SEMANTIC_RESOLUTION_ENABLED=false

# JIRA settings when CURATOR_ISSUE_TRACKER=jira
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task

# Enable with: docker compose --profile observability up --build
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-value
